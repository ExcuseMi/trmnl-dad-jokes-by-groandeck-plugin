{% template main %}
{% assign show_explanation = trmnl.plugin_settings.custom_fields_values.show_explanation | default: "true" %}
<script>var __jokes = {{ jokes | json }};</script>

<div class="layout layout--col">
  <div class="joke-setup value {% if view == 4 %}md:value--small lg:value--base{% else %}lg:value--large{% endif %} text--center mb--4 lg:mb--4"></div>
  <div class="joke-punchline value {% if view == 4 %}md:value--small lg:value--base{% else %}lg:value--large{% endif %} text--center"></div>
  {% if show_explanation == "true" %}
  <div class="joke-explanation description lg:description--large 2bit:text--gray-30 4bit:text--gray-40"></div>
  {% endif %}
</div>
<div class="title_bar">
  <img class="w--8 h--8 image image-dither" src="https://raw.githubusercontent.com/ExcuseMi/trmnl-dad-jokes-by-groandeck-plugin/refs/heads/main/assets/logo.png" />
  <span class="title">Dad Jokes</span>
  {% if view <= 2 %}<span class="instance">Courtesy of GroanDeck</span>{% endif %}
</div>

<script>
(function () {
  var views = Array.from(document.querySelectorAll('.view'));
  var script = document.currentScript;
  var ancestor = views.find(function (v) { return v.contains(script); });
  var idx = views.indexOf(ancestor) % 4;
  var joke = (__jokes || [])[idx] || {};
  var setup = ancestor.querySelector('.joke-setup');
  var punchline = ancestor.querySelector('.joke-punchline');
  var explanation = ancestor.querySelector('.joke-explanation');
  if (setup) setup.textContent = joke.setup || '';
  if (punchline) punchline.textContent = joke.punchline || '';
  if (explanation) explanation.textContent = joke.explanation || '';
})();
</script>

{% endtemplate %}
